// Entity Models: with @map and @@map for names in DBMS:
model PlantNomenclature {
  internalId          Int           @id @default(autoincrement()) @map("internal_id")
  plantScientificName String        @unique @map("scientific_name")
  plantCommonName     String[]      @map("common_names")
  plantPinyin         String?       @unique @map("pinyin") // verified as UNIQUE -- NULL possible
  plantChineseName    String?       @unique @map("chinese_name") // verified as UNIQUE -- NULL possible
  taxonomyId          Int           @map("taxonomy_id")
  taxonomy            PlantTaxonomy @relation(fields: [taxonomyId], references: [id])
  links               String[]      @map("links")

  botanicalGardenList  BotanicalGarden[] // implicit many-to-many in Prisma
  synonyms             PlantSynonym[]
  morphologies         PlantMorphology[] // implicit many-to-many in Prisma
  ecologyDistributions PlantEcologyDistribution? // one-to-one
  conservation         PlantConservation? // one-to-one

  herbalDrugs   HerbalDrugBackground[]
  ethnobotanies Ethnobotany? // one-to-one

  @@map("plant_nomenclature")
}

model PlantTaxonomy {
  id       Int                 @id @default(autoincrement()) @map("id")
  class    String?             @map("class")
  family   String              @map("family")
  vascular Boolean?            @map("is_vascular")
  plants   PlantNomenclature[]

  @@map("plant_taxonomy")
}

model PlantSynonym {
  id      Int     @id @default(autoincrement()) @map("id")
  plantId Int     @map("plant_id")
  name    String? @map("name")

  plant PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("plant_synonym")
}

model PlantMorphology {
  id                 Int         @id @default(autoincrement()) @map("id")
  lifecycle          Lifecycle[] @map("lifecycle") // refer to dataframe - enum dataframe
  isTerrestrial      Boolean?    @map("is_terrestrial")
  growthHabit        String?     @map("growth_habit") // reconcile the dataframe for spelling
  isDeciduous        Boolean?    @map("is_deciduous") //  add a note col for list value, and semi
  isDeciduousNote    String?     @map("is_deciduous_note") 
  // reproductiveSystem ReproductiveSystem? @map("reproductive_system")
  reproductiveSystem String?     @map("reproductive_system") // standardize some rows and keep the edge case values
  floweringPeriod    Month[]     @map("flowering_period")
  fruitingPeriod     Month[]     @map("fruiting_period")

  plants PlantNomenclature[] // implicit many-to-many

  @@map("plant_morphology")
}

model PlantEcologyDistribution {
  id          Int      @id @default(autoincrement()) @map("id")
  habitat     String?  @map("habitat") // unique necessary? seems not based on pivot table of this
  plantOrigin String?  @map("plant_origins") // see comments in Kanban, either String or Json - refer Pivot table
  globalRange String?  @map("global_range") // see comments in Kanban, either String or Json - refer Pivot table
  chinaRange  String?  @map("china_range") // see comments in Kanban, either String or Json - refer Pivot table
  // endemic     Boolean? @map("endemic") // add another field endemic_remarks? 
  endemic     String? @map("endemic") // show the whole value for Yes 


  plantId Int               @unique @map("plant_id")
  plant   PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("plant_ecology_distribution")
}

model PlantConservation {
  id                       Int                       @id @default(autoincrement()) @map("id")
  globalConservationStatus GlobalConservationStatus? @map("global_conservation_status")
  chinaConservationStatus  String?                   @map("china_conservation_status") // just use String for fuzzy search
  // remarks                  String?                   @map("remarks")
  // protectedStatus          ProtectedStatus?          @map("protected_status") // or enum[] TBC
  protectedStatus          String?                   @map("protected_status") // or enum[] TBC
  invasiveStatus           InvasiveStatus?           @map("invasive_status") // enum? difference in values: Possible or Potential
  invasiveRange            String?                   @map("invasive_range") // just use String for fuzzy/prefix search

  plantId Int               @unique @map("plant_id")
  plant   PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("plant_conservation")
}

model BotanicalGarden {
  id                  Int                 @id @default(autoincrement()) @map("id")
  botanicalGardenName String              @map("name")
  plants              PlantNomenclature[]

  @@map("botanical_garden")
}

model MedicinalProperties {
  id                        Int          @id @default(autoincrement()) @map("id")
  pharmaceuticalName        String?      @unique @map("pharmaceutical_name") // use col N in dataframe, some do not have values
  herbalDrugPinyin          String       @unique @map("pinyin") // every Medicinal Material has pinyin in dataframe
  taste                     Taste[]      @map("taste") // or string ? 
  energyFlow                EnergyFlow[] @map("energy_flow") // refer to dataframe; 
  meridians                 Meridian[]   @map("meridians")
  actions                   String?      @map("actions")
  pharmacologicalProperties String[]     @map("pharmacological_properties") // better use string[] which can be normalized later
  indications               String[]     @map("indications") // better use string[] which can be normalized later
  toxicity                  String?      @map("toxicity")
  // secondaryMetabolites      String[]     @map("secondary_metabolites") // values to be standardized as input,e.g., Plantainoside A, B, C, D, E, F
  secondaryMetabolites      String?     @map("secondary_metabolites") // 

  herbalDrugs HerbalDrugBackground[] // implicit many-to-many
  // HerbalDrugBackground HerbalDrugBackground[]

  @@map("medicinal_properties")
}

model HerbalDrugBackground {
  id                  Int      @id @default(autoincrement()) @map("id")
  herbalDrugPinyin    String   @map("pinyin")
  // plantPartUsed          PlantPartUsed[] @map("parts_used")
  plantPartUsed       String?  @map("parts_used") // has remarks in (), just make it String type, later we could standardize 
  // plantPartDesc          String? @map("part_description")
  officialStatus      Boolean? @map("official_status")
  harvestingTime      Month[]  @map("harvesting_time")
  primaryProcessing   String?  @map("primary_processing")
  secondaryProcessing String?  @map("secondary_processing")
  herbalDruglImage    String?  @map("herbal_drug_image")

  plantId              Int                 @map("plant_id")
  plant                PlantNomenclature   @relation(fields: [plantId], references: [internalId])
  merdicinalPropertyId Int                 @map("medicinal_property_id")
  merdicinalProperty   MedicinalProperties @relation(fields: [merdicinalPropertyId], references: [id])

  sourcingBackgrounds SourcingBackground?

  @@unique([plantId, merdicinalPropertyId])
  @@map("herbal_drug_background")
}

model SourcingBackground {
  id                    Int                  @id @default(autoincrement()) @map("id")
  herbalDrugId          Int                  @unique @map("herbal_drug_id")
  cultivationStatus     Boolean?             @map("cultivated")
  cultivationRegions    String?              @map("cultivation_regions") // use String due to remarks, prefix/partial search
  wildHarvestingRegions String?              @map("harvesting_practice") //  due to remarks, or use Json type
  harvestingPractice    HarvestingPractice[] @map("practices")
  daodiStatus           Boolean?             @map("daodi")
  daodiRegions          String?              @map("daodi_regions") // use String due to remarks, prefix/partial search, standardize later
  // daodiDesc             String?              @map("daodi_description")
  productionRegions     String?              @map("production_regions") // new col from datafram

  herbalDrug HerbalDrugBackground @relation(fields: [herbalDrugId], references: [id])

  @@map("sourcing_background")
}

model Ethnobotany {
  id                Int      @id @default(autoincrement()) @map("id")
  plantId           Int      @unique @map("plant_id")
  folkMedicinalUses String?  @map("folk_medicinal_uses")
  otherCulturalUses String[] @map("other_cultural_uses")
  references        String? @map("references") // leave blank

  plant PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("ethnobotany")
}
