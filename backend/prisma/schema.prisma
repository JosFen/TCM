// May 21 todo:
// Entity Models: with @map and @@map for names in DBMS:
model PlantNomenclature {
  internalId          Int           @id @default(autoincrement()) @map("internal_id")
  plantScientificName String        @unique @map("scientific_name")
  plantCommonName     String[]      @map("common_names")
  plantPinyin         String        @unique @map("pinyin") // verified as UNIQUE
  plantChineseName    String        @unique @map("chinese_name") // verified as UNIQUE
  taxonomyId          Int           @map("taxonomy_id")
  taxonomy            PlantTaxonomy @relation(fields: [taxonomyId], references: [id])

  botanicalGardenList  BotanicalGarden[] // implicit many-to-many in Prisma
  synonyms             PlantSynonym[]
  morphologies         PlantMorphology[]
  ecologyDistributions PlantEcologyDistribution[]
  conservation         PlantConservation?
  herbalDrugs          HerbalDrugBackground[]
  ethnobotanies        Ethnobotany[]

  @@map("plant_nomenclature")
}

model PlantTaxonomy {
  id       Int                 @id @default(autoincrement()) @map("id")
  class    String?             @map("class")
  family   String              @map("family")
  vascular Boolean?            @map("is_vascular")
  plants   PlantNomenclature[]

  @@map("plant_taxonomy")
}

model PlantSynonym {
  id      Int     @id @default(autoincrement()) @map("id")
  plantId Int     @map("plant_id")
  name    String? @map("name")

  plant PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("plant_synonym")
}

model PlantMorphology {
  id                 Int                 @id @default(autoincrement()) @map("id")
  lifecycle          Lifecycle[]         @map("lifecycle") // refer to dataframe
  isTerrestrial      Boolean?            @map("is_terrestrial")
  growthHabit        String?             @map("growth_habit")
  isDeciduous        Boolean?            @map("is_deciduous") // Semi-deciduous valid? convert to enum
  reproductiveSystem ReproductiveSystem? @map("reproductive_system")
  floweringPeriod    Month[]             @map("flowering_period")
  fruitingPeriod     Month[]             @map("fruiting_period")

  plants PlantNomenclature[] // implicit many-to-many

  @@map("plant_morphology")
}

model PlantEcologyDistribution {
  id          Int      @id @default(autoincrement()) @map("id")
  habitat     String?  @map("habitat") // unique necessary? seems not based on pivot table of this
  plantOrigin String?  @map("plant_origins") // see comments in Kanban, either String or Json - refer Pivot table
  globalRange String?  @map("global_range") // see comments in Kanban, either String or Json - refer Pivot table
  chinaRange  String?  @map("china_range") // see comments in Kanban, either String or Json - refer Pivot table
  endemic     Boolean? @map("endemic") // add another field endemic_remarks? 

  plantId Int               @map("plant_id")
  plant   PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("plant_ecology_distribution")
}

model PlantConservation {
  id                       Int                       @id @default(autoincrement()) @map("id")
  plantId                  Int                       @unique @map("plant_id")
  globalConservationStatus GlobalConservationStatus? @map("global_status")
  chinaConservationStatus  String                    @map("china_status")
  remarks                  String?                   @map("remarks")
  protectedStatus          ProtectedStatus?          @map("protected_status") // or enum[] TBC
  invasiveStatus           Boolean                   @map("invasive")
  invasiveRange            String[]                  @map("invasive_range")

  plant PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("plant_conservation")
}

model BotanicalGarden {
  id                  Int                 @id @default(autoincrement()) @map("id")
  botanicalGardenName String              @map("name")
  plants              PlantNomenclature[]

  @@map("botanical_garden")
}

model MedicinalProperties {
  id                        Int          @id @default(autoincrement()) @map("id")
  pharmaceuticalName        String       @unique @map("pharmaceutical_name")
  herbalDrugPinyin          String       @unique @map("pinyin")
  taste                     Taste[]      @map("taste") // or string ? 'slightly' not included
  energyFlow                EnergyFlow[] @map("energy_flow") // refer to dataframe; 'slightly' not included
  meridians                 Meridian[]   @map("meridians")
  actions                   String?      @map("actions")
  pharmacologicalProperties String[]     @map("pharmacological_properties")
  indications               String?      @map("indications")
  toxicity                  String?      @map("toxicity")
  secondaryMetabolites      String[]     @map("secondary_metabolites")

  herbalDrugs HerbalDrugBackground[]

  @@map("medicinal_properties")
}

model HerbalDrugBackground {
  id                     Int     @id @default(autoincrement()) @map("id")
  plantId                Int     @map("plant_id")
  medicinalPropertyId    Int     @map("medicinal_property_id")
  herbalDrugPinyin       String  @map("pinyin")
  // plantPartUsed          PlantPartUsed[] @map("parts_used")
  plantPartUsed          String? @map("parts_used")
  plantPartDesc          String? @map("part_description")
  officialStatus         Boolean @map("official_status")
  harvestingTime         Month[] @map("harvesting_time")
  primaryProcessing      String? @map("primary_processing")
  secondaryProcessing    String? @map("secondary_processing")
  medicinalMaterialImage String? @map("material_image")

  plant               PlantNomenclature    @relation(fields: [plantId], references: [internalId])
  medicinalProperty   MedicinalProperties  @relation(fields: [medicinalPropertyId], references: [id])
  sourcingBackgrounds SourcingBackground[]

  @@map("herbal_drug_background")
}

model SourcingBackground {
  id                    Int                  @id @default(autoincrement()) @map("id")
  herbalDrugId          Int                  @map("herbal_drug_id")
  cultivationStatus     Boolean              @map("cultivated")
  cultivationRegions    String[]             @map("cultivation_regions")
  wildHarvestingRegions String[]             @map("harvesting_practice")
  harvestingPractice    HarvestingPractice[] @map("practices")
  daodiStatus           Boolean?             @map("daodi")
  daodiRegions          String?              @map("daodi_regions")
  daodiDesc             String?              @map("daodi_description")

  herbalDrug HerbalDrugBackground @relation(fields: [herbalDrugId], references: [id])

  @@map("sourcing_background")
}

model Ethnobotany {
  id                Int      @id @default(autoincrement()) @map("id")
  plantId           Int      @map("plant_id")
  folkMedicinalUses String   @map("folk_uses")
  otherCulturalUses String[] @map("cultural_uses")
  references        String?  @map("references")

  plant PlantNomenclature @relation(fields: [plantId], references: [internalId])

  @@map("ethnobotany")
}
