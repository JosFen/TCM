enum Lifecycle {
  ANNUAL
  BIENNIAL
  PERENNIAL
}

enum ReproductiveSystem {
  DIOECIOUS
  MONOECIOUS
  PARADIOECIOUS
}

enum Month {
  JANUARY
  FEBRUARY
  MARCH
  APRIL
  MAY
  JUNE
  JULY
  AUGUST
  SEPTEMBER
  OCTOBER
  NOVEMBER
  DECEMBER
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
}

enum Taste {
  ACRID
  ASTRINGENT
  BITTER
  BLAND
  PUNGENT
  SALTY
  SOUR
  SWEET
}

enum EnergyFlow {
  COLD
  COOL
  HOT
  NEUTRAL
  WARM
}

enum Meridian {
  BLADDER
  GALLBLADDER
  HEART
  INTESTINE
  KIDNEY
  LARGE_INTESTINE
  LIVER
  LUNG
  PERICARDIUM
  SAN_JIAO
  SMALL_INTESTINE
  SPLEEN
  STOMACH
}

enum GlobalConservationStatus {
  CRITICALLY_ENDANGERED
  DATA_DEFICIENT
  ENDANGERED
  LEAST_CONCERN
  NEAR_THREATENED
  NOT_EVALUATED
  VULNERABLE
}

enum ProtectedStatus {
  CHINA_CAT_II // (China) Cat. II
  CHINA_SEPA_CAT_II // (China/ SEPA) Cat. II
  SEPA_CATEGORY_II // Category II (SEPA)
  CITES_APPENDIX_I // CITES: Appendix I
  CITES_APPENDIX_II // CITES: Appendix II
  WTR_ANNEX_D // WTR: Annex D
}

